# RelaySecret deploy configuration
# Copy to deploy/config.env and fill in the required values, then run:
#     ./deploy/deploy.sh --yes
#
# config.env is gitignored — never commit it.

# =====================================================================
# REQUIRED
# =====================================================================

# Cloudflare API token.
# Create one at: https://dash.cloudflare.com/profile/api-tokens
# It must be granted the following permissions (see deploy/README.md):
#   Account  -> Workers R2 Storage           : Edit
#   Account  -> Workers Scripts              : Edit
#   Account  -> Workers KV Storage           : Edit
#   Account  -> Cloudflare Pages             : Edit
#   Account  -> Account Settings             : Read
#   Zone     -> DNS                          : Edit
#   Zone     -> Workers Routes               : Edit
#   Zone     -> Zone                         : Read
# Account Resources: include the target account.
# Zone Resources:    include the target zone (DOMAIN).
CF_API_TOKEN=

# Cloudflare account id.
# Cloudflare dashboard -> any site -> right sidebar -> "Account ID".
CF_ACCOUNT_ID=

# Zone id for DOMAIN. Optional — if empty, deploy.sh will look it up from
# the Cloudflare API using DOMAIN.
CF_ZONE_ID=

# Apex domain that is already added as a zone in your Cloudflare account.
DOMAIN=relaysecret.com

# Hostname where the static site (Cloudflare Pages) will be served.
FRONTEND_HOST=www.relaysecret.com

# Hostname where the Worker API will be served.
API_HOST=api.relaysecret.com

# =====================================================================
# R2 credentials  (REQUIRED — created manually in the Cloudflare dashboard)
# =====================================================================
# The Worker needs S3-compatible R2 credentials so it can mint SigV4
# presigned PUT/GET URLs. Cloudflare does not expose a stable public API
# for creating these, so you must mint them in the dashboard:
#
#   1. Run deploy.sh once — it will create the R2 buckets (it exits with
#      an error at this step if these creds are missing; that's expected).
#   2. Visit https://dash.cloudflare.com/?to=/:account/r2/api-tokens
#      -> "Create API Token"
#      -> Permission: "Object Read & Write"
#      -> Apply to buckets: relaysecret-us, relaysecret-eu, relaysecret-apac
#      -> TTL: Forever
#   3. Copy the Access Key ID and Secret Access Key (Cloudflare shows the
#      secret exactly once).
#   4. Paste them below and re-run ./deploy/deploy.sh --yes
#
# Rotate later by creating a new token in the dashboard and re-running
# `wrangler secret put R2_ACCESS_KEY_ID / R2_SECRET_ACCESS_KEY` from worker/.
#
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# =====================================================================
# OPTIONAL
# =====================================================================

# VirusTotal API key used by the /sha1/:hash endpoint.
# Set to "none" to disable SHA1 lookups.
VT_API_KEY=none

# HMAC secret for time-bound upload tokens.
# Set to "none" to disable the HMAC gate.
HMAC_SECRET=none

# Random seed used to salt object-key generation.
# If empty, deploy.sh will auto-generate via `openssl rand -hex 32`.
SEED=

# Name of the Cloudflare Pages project. Must be lowercase, no dots.
PAGES_PROJECT=relaysecret

# Name of the Worker. Must match worker/wrangler.toml.example [name].
WORKER_NAME=relaysecret

# R2 bucket names. Keep defaults unless you have a reason to change.
R2_BUCKET_US=relaysecret-us
R2_BUCKET_EU=relaysecret-eu
R2_BUCKET_APAC=relaysecret-apac
